{
  "name": "olk",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "env:local": "cp .env.docker .env.local && echo 'Switched .env.local to the local Docker Supabase stack -- restart npm run dev.'",
    "env:remote": "cp .env.remote .env.local && echo 'Switched .env.local to the remote Supabase project -- restart npm run dev.'",
    "db:reset": "supabase db reset",
    "db:push": "supabase db push",
    "db:pull-data": "bash scripts/pull-remote-data.sh"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.2",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.14.0",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
